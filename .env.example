# Economic Dashboard Configuration
# Copy this file to .env and fill in your API keys (if needed)

# FRED API (optional - no key needed for basic series)
# FRED_API_KEY=your_fred_api_key_here

# Yahoo Finance (no API key needed for basic use)

# OANDA API (for currency data)
# OANDA_API_KEY=your_oanda_api_key_here

# Alpha Vantage (alternative data source)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
